# Copy this file to .env and fill in your values.
# .env is gitignored — never commit real credentials.

# ── Email notification (Gmail SMTP) ───────────────────────────────────────────
# Gmail requires an App Password, NOT your regular Gmail password.
# Enable it at: Google Account → Security → 2-Step Verification → App Passwords
#
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# Where to send notification emails (defaults to SMTP_USER if left blank)
NOTIFY_EMAIL=you@gmail.com
